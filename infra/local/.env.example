# One-file pattern:
# - prod uses base names (SNOWFLAKE_DATABASE, etc.)
# - dev uses *_DEV names (SNOWFLAKE_DATABASE_DEV, etc.)
# You can generate this file with: make env

APP_ENV=dev

SNOWFLAKE_ORGANIZATION=
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_ROLE_DEV=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=WH_SENTINEL
SNOWFLAKE_WAREHOUSE_DEV=WH_SENTINEL_DEV
SNOWFLAKE_DATABASE=SENTINEL
SNOWFLAKE_DATABASE_DEV=SENTINEL_DEV
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_SCHEMA_DEV=PUBLIC
SNOWFLAKE_REGION=
